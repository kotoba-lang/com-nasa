// Nasa clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace nasa {

    entity Filing {
        id: string @unique
        filerId: string
        form: string
        period: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Entity {
        id: string @unique
        name: string
        ein: string
        jurisdiction: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Dataset {
        id: string @unique
        name: string
        agency: string
        updatedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Application {
        id: string @unique
        applicantId: string
        program: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity PublicRecord {
        id: string @unique
        recordType: string
        jurisdiction: string
        recordedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Notice {
        id: string @unique
        subjectId: string
        type: string
        issuedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
